# --- Database ---
# Supabase Postgres connection string (use the pooled or direct URL).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trace

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=sources

# --- Auth ---
# Random 32+ char secret. Generate via `openssl rand -base64 32`.
# `NEXTAUTH_SECRET` is also supported for Vercel/Auth.js compatibility.
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (https://github.com/settings/developers)
# `GITHUB_CLIENT_ID` / `GITHUB_CLIENT_SECRET` are also supported.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# `GOOGLE_CLIENT_ID` / `GOOGLE_CLIENT_SECRET` are also supported.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- AI ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional, for the X-Title header used by OpenRouter.
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Trace

# Optional NVIDIA NIM routing experiment. Required only when
# TRACE_FEATURE_NIM_ROUTING=true.
NVIDIA_NIM_API_KEY=

# --- Billing / Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# --- Source integrations ---
# Product auth GitHub OAuth above remains separate from source access.
GITHUB_SOURCE_CLIENT_ID=
GITHUB_SOURCE_CLIENT_SECRET=
GITHUB_SOURCE_APP_ID=
GITHUB_SOURCE_PRIVATE_KEY=
# Optional dedicated encryption secret for integration tokens. Falls back to
# AUTH_SECRET locally, but production should set a stable dedicated value.
SOURCE_TOKEN_ENCRYPTION_KEY=

# Reserved for Phase 2.5; not required for launch.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# --- Jobs / Redis ---
REDIS_URL=redis://localhost:6379

# --- Observability ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Email ---
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@trace.dev

# --- Feature flags ---
# Set to "true" to bypass auth on API routes (dev only).
TRACE_DEV_BYPASS_AUTH=false
TRACE_ADMIN_EMAILS=
TRACE_BETA_ALLOWED_EMAILS=
TRACE_BETA_ACCESS_CODES=
TRACE_FEATURE_BILLING=false
TRACE_FEATURE_GITHUB_SYNC=false
TRACE_FEATURE_CALENDAR=false
TRACE_FEATURE_SHIP_TO_POST=false
TRACE_FEATURE_ADMIN_AI_OPS=false
TRACE_FEATURE_BETA_GATE=false
TRACE_FEATURE_NIM_ROUTING=false
TRACE_FEATURE_DRIVE_SYNC=false
TRACE_FEATURE_NOTION_SYNC=false
TRACE_FEATURE_PHASE2_VOICE=false
