# --- Database ---
# Supabase Postgres connection string (use the pooled or direct URL).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trace

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=sources

# --- Auth ---
# Random 32+ char secret. Generate via `openssl rand -base64 32`.
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (https://github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- AI ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional, for the X-Title header used by OpenRouter.
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Trace

# --- Email ---
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@trace.dev

# --- Feature flags ---
# Set to "true" to bypass auth on API routes (dev only).
TRACE_DEV_BYPASS_AUTH=false
